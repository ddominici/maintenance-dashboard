# ── Binaries ──────────────────────────────────────────────────────────────────
*.exe
*.out

# ── Configuration (production) ────────────────────────────────────────────────
# Keep config.example.yaml; exclude the real config with credentials.
configs/config.yaml
.env
# Allow .env.example to be committed as a reference template.
!.env.example

# ── Go build artifacts ────────────────────────────────────────────────────────
vendor/

# ── Frontend build output ─────────────────────────────────────────────────────
# Generated by `npm run build`; embedded into the Go binary at build time.
internal/infra/assets/dist/
web/frontend/node_modules/
web/frontend/dist/

# ── Release artifacts ─────────────────────────────────────────────────────────
_releases/

# ── OS metadata ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
